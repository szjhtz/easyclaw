{
  "name": "@rivonclaw/desktop",
  "version": "1.7.1",
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "author": "RivonClaw",
  "homepage": "https://www.rivonclaw.com",
  "description": "Desktop runtime manager for OpenClaw",
  "scripts": {
    "prebuild": "node ../../scripts/generate-plugin-ids.mjs",
    "build": "tsdown",
    "dev": "tsdown && PANEL_DEV_URL=http://localhost:5180 ELECTRON_RUN_AS_NODE= electron .",
    "lint": "oxlint",
    "test": "vitest run",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:dev": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:prod": "playwright test --config e2e/playwright.config.ts",
    "pack:__NOTE__": "WARNING: 'pack' skips rebuild-native and prune-vendor-deps, so vendor/openclaw/node_modules will be incomplete and the gateway will fail to start. Use scripts/test-local.sh for a working packaged build.",
    "pack": "electron-builder --dir",
    "dist:mac": "node scripts/prune-vendor-deps.cjs && node scripts/bundle-vendor-deps.cjs && electron-builder --mac --publish never",
    "dist:mac:arm64": "node scripts/prune-vendor-deps.cjs && node scripts/bundle-vendor-deps.cjs && electron-builder --mac dmg --arm64 --publish never && node scripts/sign-arm64.cjs",
    "dist:win": "node scripts/prune-vendor-deps.cjs && node scripts/bundle-vendor-deps.cjs && electron-builder --win --config electron-builder.win.yml --publish never",
    "dist:linux": "node scripts/prune-vendor-deps.cjs && node scripts/bundle-vendor-deps.cjs && electron-builder --linux --config electron-builder.linux.yml --publish never"
  },
  "dependencies": {
    "@rivonclaw/core": "workspace:*",
    "@rivonclaw/customer-service": "workspace:*",
    "@rivonclaw/device-id": "workspace:*",
    "@rivonclaw/gateway": "workspace:*",
    "@rivonclaw/logger": "workspace:*",
    "@rivonclaw/proxy-router": "workspace:*",
    "@rivonclaw/rules": "workspace:*",
    "@rivonclaw/secrets": "workspace:*",
    "@rivonclaw/storage": "workspace:*",
    "@rivonclaw/stt": "workspace:*",
    "@rivonclaw/telemetry": "workspace:*",
    "@rivonclaw/updater": "workspace:*",
    "@types/adm-zip": "^0.5.7",
    "@types/uuid": "^10.0.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.3.0",
    "undici": "^7.21.0",
    "uuid": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.0.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@rivonclaw/rivonclaw-browser-profiles-tools": "workspace:*",
    "@rivonclaw/rivonclaw-capability-manager": "workspace:*",
    "@rivonclaw/rivonclaw-event-bridge": "workspace:*",
    "@rivonclaw/rivonclaw-file-permissions": "workspace:*",
    "@rivonclaw/rivonclaw-mobile-chat-channel": "workspace:*",
    "@rivonclaw/rivonclaw-policy": "workspace:*",
    "@rivonclaw/rivonclaw-search-browser-fallback": "workspace:*",
    "@rivonclaw/rivonclaw-tools": "workspace:*",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.3.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "oxlint": "^1.43.0",
    "playwright": "^1.58.2",
    "tsdown": "^0.20.3",
    "vitest": "^4.0.18"
  }
}
