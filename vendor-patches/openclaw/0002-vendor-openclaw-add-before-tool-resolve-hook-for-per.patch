From 3a978bab4991e868b50d3ad0ea46986d83a8d0be Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Fri, 20 Mar 2026 13:29:32 -0700
Subject: [PATCH] vendor(openclaw): add before_tool_resolve hook for
 per-session tool filtering

Why:
- RivonClaw's capability-manager extension needs to control which tools are
  visible to the LLM on a per-session basis (ADR-031). The existing hook
  points fire too late (after tool resolution), so the system prompt and
  tool list are already built with all tools.

Removal:
- When upstream OpenClaw adds a native per-session tool filtering mechanism
  (e.g. via plugin hook or config), this patch can be dropped.

Tests:
- extensions/rivonclaw-capability-manager/src/__tests__/
---
 src/agents/pi-embedded-runner/compact.ts     | 20 +++++++++++++++-
 src/agents/pi-embedded-runner/run/attempt.ts | 23 ++++++++++++++++---
 src/plugins/hooks.ts                         | 24 ++++++++++++++++++++
 src/plugins/types.ts                         | 17 ++++++++++++++
 4 files changed, 80 insertions(+), 4 deletions(-)

diff --git a/src/agents/pi-embedded-runner/compact.ts b/src/agents/pi-embedded-runner/compact.ts
index 8c490e113d..dac68d5e36 100644
--- a/src/agents/pi-embedded-runner/compact.ts
+++ b/src/agents/pi-embedded-runner/compact.ts
@@ -555,7 +555,7 @@ export async function compactEmbeddedPiSessionDirect(
       modelContextWindowTokens: ctxInfo.tokens,
       modelAuthMode: resolveModelAuthMode(model.provider, params.config),
     });
-    const tools = sanitizeToolsForGoogle({
+    let tools = sanitizeToolsForGoogle({
       tools: supportsModelTools(model) ? toolsRaw : [],
       provider,
     });
@@ -656,6 +656,23 @@ export async function compactEmbeddedPiSessionDirect(
     });
     const ttsHint = params.config ? buildTtsSystemPromptHint(params.config) : undefined;
     const ownerDisplay = resolveOwnerDisplaySetting(params.config);
+
+    // before_tool_resolve hook: filter tools BEFORE system prompt is built (ADR-031).
+    {
+      const earlyHookRunner = getGlobalHookRunner();
+      if (earlyHookRunner?.hasHooks("before_tool_resolve")) {
+        const toolNames = tools.map((t: { name: string }) => t.name);
+        const hookResult = await earlyHookRunner.runBeforeToolResolve(
+          { tools: toolNames },
+          { agentId: sessionAgentId, sessionKey: params.sessionKey?.trim() || params.sessionId },
+        );
+        if (hookResult?.tools) {
+          const allowed = new Set(hookResult.tools);
+          tools = tools.filter((t: { name: string }) => allowed.has(t.name));
+        }
+      }
+    }
+
     const appendPrompt = buildEmbeddedSystemPrompt({
       workspaceDir: effectiveWorkspace,
       defaultThinkLevel: params.thinkLevel,
@@ -738,6 +755,7 @@ export async function compactEmbeddedPiSessionDirect(
         await resourceLoader.reload();
       }
 
+      // Tools already filtered by before_tool_resolve hook above (before system prompt build).
       const { builtInTools, customTools } = splitSdkTools({
         tools,
         sandboxEnabled: !!sandbox?.enabled,
diff --git a/src/agents/pi-embedded-runner/run/attempt.ts b/src/agents/pi-embedded-runner/run/attempt.ts
index 274ef0ef86..49cd96effc 100644
--- a/src/agents/pi-embedded-runner/run/attempt.ts
+++ b/src/agents/pi-embedded-runner/run/attempt.ts
@@ -1530,10 +1530,28 @@ export async function runEmbeddedAttempt(
           },
         });
     const toolsEnabled = supportsModelTools(params.model);
-    const tools = sanitizeToolsForGoogle({
+    let tools = sanitizeToolsForGoogle({
       tools: toolsEnabled ? toolsRaw : [],
       provider: params.provider,
     });
+
+    // before_tool_resolve hook: filter tools BEFORE system prompt is built (ADR-031).
+    // This ensures both the tool list AND the system prompt only include selected tools.
+    {
+      const earlyHookRunner = getGlobalHookRunner();
+      if (earlyHookRunner?.hasHooks("before_tool_resolve")) {
+        const toolNames = tools.map((t: { name: string }) => t.name);
+        const hookResult = await earlyHookRunner.runBeforeToolResolve(
+          { tools: toolNames },
+          { agentId: sessionAgentId, sessionKey: sandboxSessionKey },
+        );
+        if (hookResult?.tools) {
+          const allowed = new Set(hookResult.tools);
+          tools = tools.filter((t: { name: string }) => allowed.has(t.name));
+        }
+      }
+    }
+
     const clientTools = toolsEnabled ? params.clientTools : undefined;
     const allowedToolNames = collectAllowedToolNames({
       tools,
@@ -1789,9 +1807,8 @@ export async function runEmbeddedAttempt(
         await resourceLoader.reload();
       }
 
-      // Get hook runner early so it's available when creating tools
+      // Tools already filtered by before_tool_resolve hook above (before system prompt build).
       const hookRunner = getGlobalHookRunner();
-
       const { builtInTools, customTools } = splitSdkTools({
         tools,
         sandboxEnabled: !!sandbox?.enabled,
diff --git a/src/plugins/hooks.ts b/src/plugins/hooks.ts
index 110d717d78..f83287d245 100644
--- a/src/plugins/hooks.ts
+++ b/src/plugins/hooks.ts
@@ -56,6 +56,8 @@ import type {
   PluginHookBeforeBrowserActionEvent,
   PluginHookBeforeBrowserActionResult,
   PluginHookAfterBrowserActionEvent,
+  PluginHookBeforeToolResolveEvent,
+  PluginHookBeforeToolResolveResult,
 } from "./types.js";
 
 // Re-export types for consumers
@@ -100,6 +102,8 @@ export type {
   PluginHookGatewayContext,
   PluginHookGatewayStartEvent,
   PluginHookGatewayStopEvent,
+  PluginHookBeforeToolResolveEvent,
+  PluginHookBeforeToolResolveResult,
 };
 
 export type HookRunnerLogger = {
@@ -445,6 +449,25 @@ export function createHookRunner(registry: PluginRegistry, options: HookRunnerOp
   // Tool Hooks
   // =========================================================================
 
+  /**
+   * Run before_tool_resolve hook.
+   * Allows plugins to filter the tool list before session creation.
+   * Runs sequentially; last result wins for the tools array.
+   */
+  async function runBeforeToolResolve(
+    event: PluginHookBeforeToolResolveEvent,
+    ctx: PluginHookAgentContext,
+  ): Promise<PluginHookBeforeToolResolveResult | undefined> {
+    return runModifyingHook<"before_tool_resolve", PluginHookBeforeToolResolveResult>(
+      "before_tool_resolve",
+      event,
+      ctx,
+      (acc, next) => ({
+        tools: next.tools ?? acc?.tools,
+      }),
+    );
+  }
+
   /**
    * Run before_tool_call hook.
    * Allows plugins to modify or block tool calls.
@@ -807,6 +830,7 @@ export function createHookRunner(registry: PluginRegistry, options: HookRunnerOp
     runMessageSending,
     runMessageSent,
     // Tool hooks
+    runBeforeToolResolve,
     runBeforeToolCall,
     runAfterToolCall,
     runToolResultPersist,
diff --git a/src/plugins/types.ts b/src/plugins/types.ts
index bb79a21103..1757819e24 100644
--- a/src/plugins/types.ts
+++ b/src/plugins/types.ts
@@ -446,6 +446,7 @@ export type PluginHookName =
   | "subagent_ended"
   | "gateway_start"
   | "gateway_stop"
+  | "before_tool_resolve"
   | "browser_session_start"
   | "browser_session_end"
   | "before_browser_action"
@@ -476,6 +477,7 @@ export const PLUGIN_HOOK_NAMES = [
   "subagent_ended",
   "gateway_start",
   "gateway_stop",
+  "before_tool_resolve",
   "browser_session_start",
   "browser_session_end",
   "before_browser_action",
@@ -714,6 +716,17 @@ export type PluginHookToolContext = {
   toolCallId?: string;
 };
 
+// before_tool_resolve hook — allows plugins to filter the tool list before session creation
+export type PluginHookBeforeToolResolveEvent = {
+  /** Tool names available for this session. */
+  tools: string[];
+};
+
+export type PluginHookBeforeToolResolveResult = {
+  /** Filtered tool names. Tools not in this list are removed from the session. */
+  tools?: string[];
+};
+
 // before_tool_call hook
 export type PluginHookBeforeToolCallEvent = {
   toolName: string;
@@ -982,6 +995,10 @@ export type PluginHookHandlerMap = {
     event: PluginHookMessageSentEvent,
     ctx: PluginHookMessageContext,
   ) => Promise<void> | void;
+  before_tool_resolve: (
+    event: PluginHookBeforeToolResolveEvent,
+    ctx: PluginHookAgentContext,
+  ) => Promise<PluginHookBeforeToolResolveResult | void> | PluginHookBeforeToolResolveResult | void;
   before_tool_call: (
     event: PluginHookBeforeToolCallEvent,
     ctx: PluginHookToolContext,
