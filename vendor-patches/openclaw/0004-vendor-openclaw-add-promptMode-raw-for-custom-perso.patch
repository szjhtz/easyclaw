diff --git a/src/agents/system-prompt.ts b/src/agents/system-prompt.ts
index 848222b788..c3417ce41e 100644
--- a/src/agents/system-prompt.ts
+++ b/src/agents/system-prompt.ts
@@ -13,8 +13,9 @@ import { sanitizeForPromptLiteral } from "./sanitize-for-prompt.js";
  * - "full": All sections (default, for main agent)
  * - "minimal": Reduced sections (Tooling, Workspace, Runtime) - used for subagents
  * - "none": Just basic identity line, no sections
+ * - "raw": Only extraSystemPrompt, no hardcoded sections (for custom persona agents)
  */
-export type PromptMode = "full" | "minimal" | "none";
+export type PromptMode = "full" | "minimal" | "none" | "raw";
 type OwnerIdDisplay = "raw" | "hash";
 
 function buildSkillsSection(params: { skillsPrompt?: string; readToolName: string }) {
@@ -414,6 +415,14 @@ export function buildAgentSystemPrompt(params: {
   });
   const workspaceNotes = (params.workspaceNotes ?? []).map((note) => note.trim()).filter(Boolean);
 
+  // For "raw" mode, return only the caller-supplied extraSystemPrompt with no
+  // hardcoded identity, safety, runtime, or tooling sections. This lets the
+  // caller fully control the agent persona (e.g. customer-service agents that
+  // must not reveal they are AI).
+  if (promptMode === "raw") {
+    return extraSystemPrompt ?? "";
+  }
+
   // For "none" mode, return just the basic identity line
   if (promptMode === "none") {
     return "You are a personal assistant running inside OpenClaw.";
