 src/agents/pi-embedded-runner/run/attempt.ts | 139 +++++++++++--------
 src/plugins/hooks.ts                         |  26 ++++
 src/plugins/types.ts                         |  17 +++
 4 files changed, 140 insertions(+), 62 deletions(-)

